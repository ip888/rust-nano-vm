# Copy this file to `.env.local` and fill in for local dev.
# `.env.local` is gitignored.

# Base URL of the nanovm control-plane API. The dashboard makes all
# calls against this host. Locally, this is the address `nanovm-control-plane`
# binds to (default `127.0.0.1:8080`). In prod, set to your API host.
#
# NB: the control plane needs `NANOVM_CORS_ORIGIN` set to this
# dashboard's origin, otherwise the browser will drop the responses.
NEXT_PUBLIC_NANOVM_API_URL=http://localhost:8080
