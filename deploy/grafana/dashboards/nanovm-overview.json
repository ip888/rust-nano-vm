{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Operator-facing overview of nanovm-control-plane: fork throughput, latency, quota throttling, warm-pool hit rate, and per-caller top-N. Drop into Grafana, point each panel's datasource at your Prometheus, done.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "iteration": 1,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": false,
      "keepTime": true,
      "tags": ["nanovm"],
      "targetBlank": true,
      "title": "rust-nano-vm GitHub",
      "tooltip": "Project on GitHub",
      "type": "link",
      "url": "https://github.com/ip888/rust-nano-vm"
    }
  ],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "red", "index": 0, "text": "DOWN" } }, "type": "value" },
            { "options": { "1": { "color": "green", "index": 1, "text": "UP" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "title": "Status",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "min(nanovm_up{job=\"$job\"})",
          "legendFormat": "control-plane",
          "refId": "A"
        }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Forks/sec averaged over the last 5m. Spikes here are the headline product-usage signal.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "decimals": 2,
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 10, "x": 4, "y": 0 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }
      },
      "title": "Forks per second",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(nanovm_forks_total{job=\"$job\"}[5m]))",
          "legendFormat": "total",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Average fork latency (ms) over the last 5m. Computed as rate(sum)/rate(count). Watch for sustained drift above the warm-pool floor.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "decimals": 2,
          "unit": "ms"
        }
      },
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 0 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }
      },
      "title": "Average fork latency",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(nanovm_fork_latency_ms_sum{job=\"$job\"}[5m]) / clamp_min(rate(nanovm_fork_latency_ms_count{job=\"$job\"}[5m]), 1)",
          "legendFormat": "avg ms",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Percentage of forks served from the warm pool — the sub-millisecond hot path. Drops here are the first signal that the pool isn't refilling fast enough for current demand.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 8 },
      "id": 4,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "title": "Warm-pool hit rate (5m)",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(nanovm_warm_pool_hits_total{job=\"$job\"}[5m]) / clamp_min(rate(nanovm_warm_pool_hits_total{job=\"$job\"}[5m]) + rate(nanovm_warm_pool_misses_total{job=\"$job\"}[5m]), 1)",
          "legendFormat": "hit %",
          "refId": "A"
        }
      ],
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Quota throttles per second, summed across callers. Sustained non-zero here means real users are hitting the rate limit — re-tune NANOVM_FORK_QUOTA_* or upsell.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "decimals": 2,
          "unit": "ops"
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 8 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" }
      },
      "title": "Throttled forks/sec",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(nanovm_fork_quota_throttled_total{job=\"$job\"}[5m]))",
          "legendFormat": "throttles/sec",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Top 10 callers by lifetime fork count. Use to spot anomalies (one token dominating the whole fleet's quota).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "decimals": 0
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 8 },
      "id": 6,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Top 10 callers (lifetime forks)",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "topk(10, sum by (token) (nanovm_forks_total{job=\"$job\"}))",
          "legendFormat": "{{token}}",
          "refId": "A"
        }
      ],
      "type": "bargauge"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["nanovm", "microvm", "kvm"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "default", "value": "default" },
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "current": { "selected": false, "text": "nanovm", "value": "nanovm" },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(nanovm_up, job)",
        "hide": 0,
        "includeAll": false,
        "label": "Scrape job",
        "multi": false,
        "name": "job",
        "options": [],
        "query": { "query": "label_values(nanovm_up, job)", "refId": "PrometheusVariableQueryEditor-VariableQuery" },
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "sort": 0,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "title": "nanovm — overview",
  "uid": "nanovm-overview",
  "version": 1
}
