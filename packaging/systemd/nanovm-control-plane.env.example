# Environment file for nanovm-control-plane.service.
#
# Install to /etc/nanovm/control-plane.env (the service unit reads
# this path with `EnvironmentFile=`). Set restrictive permissions
# because NANOVM_API_TOKENS is a secret:
#
#   sudo install -d -o root -g nanovm -m 0750 /etc/nanovm
#   sudo install -o root -g nanovm -m 0640 \
#       packaging/systemd/nanovm-control-plane.env.example \
#       /etc/nanovm/control-plane.env
#
# Then edit and at minimum set NANOVM_API_TOKENS. Leaving it unset
# disables auth and starts the binary in dev mode — the unit will
# still boot but the binary logs a WARN line on startup.

# Bind address. The systemd unit's hardening allows AF_INET +
# AF_INET6 listeners. Default 127.0.0.1 only — front this with a
# reverse proxy that terminates TLS, or change to 0.0.0.0 if you
# accept the unencrypted listener (NOT recommended for any reachable
# deployment).
NANOVM_CONTROL_PLANE_ADDR=127.0.0.1:8080

# Bearer tokens — comma-separated. REQUIRED for any reachable
# deployment. See docs/runbook.md § Rotate API tokens.
# NANOVM_API_TOKENS=

# Per-token rate limit. Default 100 rps. Pick a value the legitimate
# caller can sustain; 0 disables (NOT recommended, WARN logged).
NANOVM_RATE_LIMIT_RPS=100
# NANOVM_RATE_LIMIT_BURST=  # defaults to rps

# Graceful-drain budget on SIGTERM. The unit's TimeoutStopSec must
# be >= this value so systemd doesn't SIGKILL before the binary
# self-exits.
NANOVM_SHUTDOWN_GRACE_SECS=30

# tracing filter directive. `info` is fine for production; bump to
# `debug,control_plane=trace` when triaging.
RUST_LOG=info
